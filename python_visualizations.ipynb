    "# VIZ 5 — Explanatory pictogram / unit chart\n",
    "\n",
    "# Use only country-year observations with at least some recorded displacement\n",
    "pictogram_df = viz_df[viz_df[\"total_displaced\"] > 0].copy()\n",
    "\n",
    "# Simple and explainable definition:\n",
    "# \"high displacement\" = top 25% of country-year observations by total_displaced\n",
    "# \"low displacement\" = bottom 25%\n",
    "q25 = pictogram_df[\"total_displaced\"].quantile(0.25)\n",
    "q75 = pictogram_df[\"total_displaced\"].quantile(0.75)\n",
    "\n",
    "low_displacement_group = pictogram_df[pictogram_df[\"total_displaced\"] <= q25]\n",
    "high_displacement_group = pictogram_df[pictogram_df[\"total_displaced\"] >= q75]\n",
    "\n",
    "pictogram_summary = pd.DataFrame({\n",
    "    \"group\": [\"Low displacement\", \"High displacement\"],\n",
    "    \"avg_mortality_1t4\": [\n",
    "        low_displacement_group[\"mortality_1t4\"].mean(),\n",
    "        high_displacement_group[\"mortality_1t4\"].mean()\n",
    "    ],\n",
    "    \"median_displaced\": [\n",
    "        low_displacement_group[\"total_displaced\"].median(),\n",
    "        high_displacement_group[\"total_displaced\"].median()\n",
    "    ],\n",
    "    \"n_country_years\": [\n",
    "        len(low_displacement_group),\n",
    "        len(high_displacement_group)\n",
    "    ]\n",
    "})\n",
    "\n",
    "pictogram_summary[\"children_per_1000\"] = (\n",
    "    pictogram_summary[\"avg_mortality_1t4\"]\n",
    "    .round()\n",
    "    .astype(int)\n",
    ")\n",
    "\n",
    "pictogram_summary"
   ]
