    "fig = px.line_polar(\n",
    "    radial_df,\n",
    "    r=\"mortality_1t4\",\n",
    "    theta=\"year\",\n",
    "    color=\"country_name\",\n",
    "    line_close=False,\n",
    "    markers=True,\n",
    "    hover_name=\"country_name\",\n",
    "    hover_data={\n",
    "        \"year\": True,\n",
    "        \"mortality_1t4\": \":.2f\",\n",
    "        \"total_displaced\": \":,.0f\",\n",
    "        \"country_name\": False\n",
    "    },\n",
    "    title=\"Radial timeline: child mortality trajectories in highly displaced countries\"\n",
    ")\n",
    "\n",
    "fig.update_traces(\n",
    "    line=dict(width=2),\n",
    "    marker=dict(size=6)\n",
    ")\n",
    "\n",
    "fig.update_layout(\n",
    "    width=850,\n",
    "    height=750,\n",
    "    polar=dict(\n",
    "        radialaxis=dict(\n",
    "            title=\"Mortality age 1–4<br>deaths per 1,000\",\n",
    "            visible=True,\n",
    "            gridcolor=\"lightgray\"\n",
    "        ),\n",
    "        angularaxis=dict(\n",
    "            tickmode=\"array\",\n",
    "            tickvals=list(range(2010, 2023)),\n",
    "            ticktext=[str(year) for year in range(2010, 2023)],\n",
    "            direction=\"clockwise\"\n",
    "        )\n",
    "    ),\n",
    "    legend_title_text=\"Country\",\n",
    "    title=dict(\n",
    "        text=\"Radial timeline: how child mortality changes through years of displacement\",\n",
    "        x=0.5\n",
    "    )\n",
    ")\n",
    "\n",
    "fig.show()"
   ]
