   "source": [
    "# VIZ 6 — Creative radial timeline\n",
    "\n",
    "# Select the top 10 countries by average displacement over the period\n",
    "top10_countries = (\n",
    "    viz_df.groupby(\"country_name\", as_index=False)[\"total_displaced\"]\n",
    "    .mean()\n",
    "    .sort_values(\"total_displaced\", ascending=False)\n",
    "    .head(10)[\"country_name\"]\n",
    ")\n",
    "\n",
    "radial_df = viz_df[viz_df[\"country_name\"].isin(top10_countries)].copy()\n",
    "\n",
    "# Ensure correct temporal order\n",
    "radial_df = radial_df.sort_values([\"country_name\", \"year\"])\n",
    "\n",
    "# More readable displacement variable for tooltips and color scales\n",
    "radial_df[\"displacement_millions\"] = radial_df[\"total_displaced\"] / 1_000_000\n",
    "\n",
    "# More readable hover label\n",
    "radial_df[\"hover_text\"] = (\n",
    "    radial_df[\"country_name\"]\n",
    "    + \"<br>Year: \" + radial_df[\"year\"].astype(str)\n",
    "    + \"<br>Mortality age 1–4: \" + radial_df[\"mortality_1t4\"].round(2).astype(str)\n",
    "    + \" deaths per 1,000\"\n",
    "    + \"<br>Total displaced: \" + radial_df[\"total_displaced\"].round(0).astype(int).astype(str)\n",
    ")\n",
    "\n",
    "radial_df.head()"
   ]
  },
